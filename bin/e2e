#!/usr/bin/env bash
# Run the Playwright e2e suite against the Rust backend end to end:
#   - build the frontend bundle and the release server,
#   - create a fresh e2e database,
#   - start the server on :4001 serving the bundle + socket,
#   - run the specs (baseURL :4001), then stop the server.
#
# The phase3/phase8 specs restart the server mid-run via bin/restart-e2e,
# which shares the pidfile + port below. Args are passed through to playwright
# (e.g. `bin/e2e phase9`).
set -euo pipefail

cd "$(dirname "$0")/.."
REPO="$(pwd)"

# Ensure cargo is reachable (rustup installs to ~/.cargo/bin, not always on PATH).
export PATH="$HOME/.cargo/bin:$PATH"

export SIM_PORT="${SIM_PORT:-4001}"
export SIM_DATABASE_URL="${SIM_DATABASE_URL:-postgres://postgres@127.0.0.1:5432/sim_e2e}"
export SIM_STATIC_DIR="$REPO/frontend/dist"
export SIM_PIDFILE="${SIM_PIDFILE:-/tmp/sim-e2e.pid}"
export SIM_LOG="${SIM_LOG:-/tmp/sim-e2e.log}"
export E2E_BASE_URL="${E2E_BASE_URL:-http://localhost:$SIM_PORT}"

# Use the cached browsers if the configured path doesn't actually have them
# (some images preset PLAYWRIGHT_BROWSERS_PATH to an empty dir).
if ! ls "${PLAYWRIGHT_BROWSERS_PATH:-/nonexistent}"/chromium* >/dev/null 2>&1 \
  && ls "$HOME/.cache/ms-playwright"/chromium* >/dev/null 2>&1; then
  export PLAYWRIGHT_BROWSERS_PATH="$HOME/.cache/ms-playwright"
fi

# Stop any server on the e2e port — including leftovers from a prior run whose
# pid the pidfile no longer tracks (matched by SIM_PORT in /proc/<pid>/environ,
# so the dev server on :4000 is left alone).
kill_e2e_servers() {
  local pid
  for pid in $(pgrep -f 'target/release/server' 2>/dev/null || true); do
    if tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | grep -qx "SIM_PORT=$SIM_PORT"; then
      kill -TERM "$pid" 2>/dev/null || true
    fi
  done
}

# Fresh database — the Rust server creates its own schema on connect. Stop any
# prior e2e server and drop its lingering connections so the drop succeeds.
[ -f "$SIM_PIDFILE" ] && { kill -TERM "$(cat "$SIM_PIDFILE")" 2>/dev/null || true; rm -f "$SIM_PIDFILE"; }
kill_e2e_servers
sleep 1
psql -h 127.0.0.1 -U postgres -d postgres -c \
  "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='sim_e2e' AND pid<>pg_backend_pid();" \
  >/dev/null 2>&1 || true
dropdb --if-exists -h 127.0.0.1 -U postgres sim_e2e
createdb -h 127.0.0.1 -U postgres sim_e2e

# Build the bundle the server will serve, and the server itself.
( cd frontend && npm run build )
( cd sim && cargo build --release --bin server )

cleanup() {
  [ -f "$SIM_PIDFILE" ] && { kill -TERM "$(cat "$SIM_PIDFILE")" 2>/dev/null || true; rm -f "$SIM_PIDFILE"; }
  kill_e2e_servers
}
trap cleanup EXIT

# Start the e2e server (serving the freshly-built bundle).
( cd sim && \
  nohup ./target/release/server >"$SIM_LOG" 2>&1 &
  echo $! >"$SIM_PIDFILE" )
for _ in $(seq 1 120); do
  curl -sf -o /dev/null "http://127.0.0.1:$SIM_PORT/" && break
  sleep 0.25
done

( cd frontend && npx playwright test "$@" )
